# ── LLM (required) ─────────────────────────────────────────────
# Any OpenAI-compatible provider. Defaults target OpenRouter's free tier
# (https://openrouter.ai). For Gemini instead, set:
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── CRM (optional) ─────────────────────────────────────────────
# none | sheets | hubspot
CRM_PROVIDER=none

# Google Sheets adapter (when CRM_PROVIDER=sheets)
SHEETS_CREDENTIALS_PATH=credentials.json
SHEETS_SPREADSHEET_NAME=Auralis_Leads_CRM
SHEETS_WORKSHEET_NAME=Leads

# ── App ────────────────────────────────────────────────────────
APP_ENV=development
DATABASE_PATH=auralis.db
ALLOWED_ORIGINS=*
