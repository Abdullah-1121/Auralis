# ── LLM (required) ─────────────────────────────────────────────
# Any OpenAI-compatible provider. Defaults target OpenRouter's free tier
# (https://openrouter.ai). For Gemini instead, set:
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Notifications (optional) ───────────────────────────────────
# Slack incoming webhook - when set, Auralis posts each finished call
# with a link to the review/approval page. Empty = skipped.
SLACK_WEBHOOK_URL=
# Public URL of this app, used in Slack links
PUBLIC_BASE_URL=http://127.0.0.1:8010

# ── Outbound email (optional) ──────────────────────────────────
# When set, approving a follow-up actually sends it via SMTP.
# For Gmail: create an App Password (myaccount.google.com/apppasswords).
# Empty = approval works, dispatch is recorded as skipped.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=Auralis

# ── CRM (optional) ─────────────────────────────────────────────
# none | sheets | hubspot
CRM_PROVIDER=none

# Google Sheets adapter (when CRM_PROVIDER=sheets)
SHEETS_CREDENTIALS_PATH=credentials.json
SHEETS_SPREADSHEET_NAME=Auralis_Leads_CRM
SHEETS_WORKSHEET_NAME=Leads

# ── App ────────────────────────────────────────────────────────
APP_ENV=development
DATABASE_PATH=auralis.db
ALLOWED_ORIGINS=*
# "user:password" - REQUIRED on public deployments (locks every route
# except /health behind HTTP Basic auth). Empty = open, local dev only.
BASIC_AUTH=
